/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART3_UART_Init();
  MX_CAN1_Init();
  /* USER CODE BEGIN 2 */
  uint32_t prev = HAL_GetTick();
  uint32_t now = HAL_GetTick();
  BriterEncoderLib_Init(&encoderLib, ENCODER_ID, TOTAL_COUNTS, RESOLUTION_MM, MAX_STEP_COUNTS);

#if CAN_ENABLE_AUTO_BAUD_SCAN
  for (uint8_t i = 0U; i < (uint8_t)(sizeof(g_baudScanOrder) / sizeof(g_baudScanOrder[0])); i++) {
	  if (g_baudScanOrder[i] == CAN_RUN_BAUD_CODE) {
		  g_baudScanIdx = i;
		  break;
	  }
  }
#endif

  currentRunBaudCode = CAN_BOOT_BAUD_CODE;
  if ((CAN_PUSH_BAUD_TO_ENCODER_AT_BOOT != 0U) && (CAN_RUN_BAUD_CODE != CAN_BOOT_BAUD_CODE)) {
	  HAL_StatusTypeDef setSt = CAN_SetEncoderBaudAndWaitAck(CAN_RUN_BAUD_CODE);
	  if (setSt == HAL_OK) {
		  if (CAN_ReInitForBaudCode(CAN_RUN_BAUD_CODE) == HAL_OK) {
			  currentRunBaudCode = CAN_RUN_BAUD_CODE;
#if UART_LOG_ENABLE
			  printf("SET_BAUD ACK, host->run=%u\r\n", (unsigned int)CAN_RUN_BAUD_CODE);
#endif
		  } else {
#if UART_LOG_ENABLE
			  printf("SET_BAUD ACK, host reinit failed\r\n");
#endif
		  }
	  } else {
		  if (CAN_ReInitForBaudCode(CAN_RUN_BAUD_CODE) == HAL_OK) {
			  if (CAN_ProbeReadAtCurrentBaud(400U) != 0U) {
				  currentRunBaudCode = CAN_RUN_BAUD_CODE;
#if UART_LOG_ENABLE
				  printf("SET_BAUD no ACK, but run baud alive=%u\r\n", (unsigned int)CAN_RUN_BAUD_CODE);
#endif
			  } else {
				  (void)CAN_ReInitForBaudCode(CAN_BOOT_BAUD_CODE);
				  currentRunBaudCode = CAN_BOOT_BAUD_CODE;
#if UART_LOG_ENABLE
				  printf("SET_BAUD no ACK, keep boot baud=%u\r\n", (unsigned int)CAN_BOOT_BAUD_CODE);
#endif
			  }
		  } else {
#if UART_LOG_ENABLE
			  printf("SET_BAUD no ACK, keep boot baud=%u\r\n", (unsigned int)CAN_BOOT_BAUD_CODE);
#endif
		  }
	  }
  } else if (CAN_RUN_BAUD_CODE != CAN_BOOT_BAUD_CODE) {
	  if (CAN_ReInitForBaudCode(CAN_RUN_BAUD_CODE) == HAL_OK) {
		  currentRunBaudCode = CAN_RUN_BAUD_CODE;
	  }
  }
  lastRxAt = now;
#if UART_LOG_ENABLE
  printf("\r\nFW_V3_PROD_READ | boot=%u run=%u profile=%lu\r\n",
		 (unsigned int)CAN_BOOT_BAUD_CODE,
		 (unsigned int)CAN_RUN_BAUD_CODE,
		 (unsigned long)CAN_TIMING_PROFILE);
#endif

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	if (canRxPending != 0U) {
		uint8_t rx[8];
		uint8_t dlc;
		uint16_t stdid;
		int32_t rawSigned;
		float disp;

		__disable_irq();
		dlc = canRxLen;
		stdid = canRxStdId;
		for (uint8_t i = 0U; i < 8U; i++) {
			rx[i] = canRxData[i];
		}
		canRxPending = 0U;
		__enable_irq();

		rawSigned = BriterEncoderLib_DecodeRawLE(rx);
		if (BriterEncoderLib_AcceptStep(&encoderLib, rawSigned) == 0U) {
			continue;
		}

		encoderValue = rawSigned;
		if (BriterEncoderLib_AutoBaseline(&encoderLib, encoderValue) != 0U) {
#if UART_LOG_ENABLE
			printf("Auto baseline: %ld\r\n", (long)encoderLib.baseline);
#endif
		}

		disp = BriterEncoderLib_DisplacementMm(&encoderLib, encoderValue);
#if UART_LOG_ENABLE
		if ((HAL_GetTick() - lastPrintAt) >= PRINT_INTERVAL_MS) {
			printf("RX id=0x%03X dlc=%u | Raw: %6ld | Disp: %8.3f mm\r\n",
			       (unsigned int)stdid, (unsigned int)dlc, (long)encoderValue, (double)disp);
			lastPrintAt = HAL_GetTick();
		}
#else
		(void)disp;
		(void)dlc;
		(void)stdid;
#endif
	}

	if ((HAL_GetTick() - prev) >= REQUEST_INTERVAL_MS) {
		if (requestPending == 0U) {
			reqEncoderValue();
		} else if ((HAL_GetTick() - requestSentAt) > RESPONSE_TIMEOUT_MS) {
			(void)HAL_CAN_AbortTxRequest(&hcan1, CAN_TX_MAILBOX0 | CAN_TX_MAILBOX1 | CAN_TX_MAILBOX2);
			requestPending = 0U;
		}
		prev = HAL_GetTick();
	}

#if CAN_ENABLE_AUTO_BAUD_SCAN
	if ((canRxSeen == 0U) && ((HAL_GetTick() - lastRxAt) >= CAN_AUTO_SCAN_STEP_MS)) {
		uint8_t n = (uint8_t)(sizeof(g_baudScanOrder) / sizeof(g_baudScanOrder[0]));
		g_baudScanIdx = (uint8_t)((g_baudScanIdx + 1U) % n);
		currentRunBaudCode = g_baudScanOrder[g_baudScanIdx];
		if (CAN_ReInitForBaudCode(currentRunBaudCode) == HAL_OK) {
			requestPending = 0U;
			lastRxAt = HAL_GetTick();
			printf("AUTO_BAUD trying code=%u\r\n", (unsigned int)currentRunBaudCode);
		}
	}
#endif
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

