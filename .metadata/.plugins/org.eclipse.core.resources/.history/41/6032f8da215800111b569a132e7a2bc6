void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
  CAN_RxHeaderTypeDef rxHeader;
  uint8_t rxData[8];

  if (hcan->Instance != CAN1) {
    return;
  }

  if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHeader, rxData) != HAL_OK) {
    return;
  }

  if ((rxHeader.IDE == CAN_ID_STD) &&
      (rxHeader.DLC >= 4U) &&
      (rxData[0] == 0x04U) &&
      ((rxData[2] == CMD_SET_ID) || (rxData[2] == CMD_SET_BAUD))) {
    /* Command replies are short 4-byte frames; keep the last one for boot-time state changes. */
    cmdAckSeen = 1U;
    cmdAckType = rxData[2];
    cmdAckCode = rxData[3];
#if UART_LOG_ENABLE
    printf("RX ACK cmd=0x%02X code=%u id=0x%02X\r\n",
           (unsigned int)cmdAckType,
           (unsigned int)cmdAckCode,
           (unsigned int)rxHeader.StdId);
#endif
    return;
  }

  if ((rxHeader.IDE == CAN_ID_STD) &&
      BriterEncoderLib_IsReadEcho(rxData, rxHeader.DLC)) {
    return;
  }

  if (rxHeader.IDE != CAN_ID_STD) {
    return;
  }

  if (BriterEncoderLib_IsReadResponseFrame(rxHeader.StdId,
                                           rxHeader.DLC,
                                           rxData,
                                           activeEncoderId) != 0U) {
    /* A valid read response is enough to prove the encoder is alive on this ID/baud pair. */
    readSeen = 1U;
  }
}

