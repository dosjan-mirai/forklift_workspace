static uint8_t CAN_ProbeReadForId(uint8_t encoderId, uint32_t timeoutMs)
{
  uint32_t t0 = HAL_GetTick();

  activeEncoderId = encoderId;
  readSeen = 0U;

  while ((HAL_GetTick() - t0) < timeoutMs) {
    /* Keep issuing read requests until we get a matching response or the probe times out. */
    if ((HAL_GetTick() - requestSentAt) >= 20U) {
      (void)CAN_SendReadRequest(encoderId);
      requestSentAt = HAL_GetTick();
    }

    if (readSeen != 0U) {
#if UART_LOG_ENABLE
      printf("READ OK id=0x%02X\r\n", encoderId);
#endif
      return 1U;
    }
  }

  return 0U;
}

static HAL_StatusTypeDef CAN_WaitForAck(uint8_t expectedCmd, uint32_t timeoutMs)
{
  uint32_t t0 = HAL_GetTick();

  cmdAckSeen = 0U;
  cmdAckCode = 0xFFU;
  cmdAckType = 0x00U;

  while ((HAL_GetTick() - t0) < timeoutMs) {
    if ((cmdAckSeen != 0U) && (cmdAckType == expectedCmd)) {
      return HAL_OK;
    }
  }

  return HAL_TIMEOUT;
}

static HAL_StatusTypeDef CAN_EnsureTargetId(void)
{
  if (ENCODER_CURRENT_ID == ENCODER_TARGET_ID) {
#if UART_LOG_ENABLE
    printf("ID change skipped\r\n");
#endif
    activeEncoderId = ENCODER_TARGET_ID;
    return HAL_OK;
  }

  if (CAN_ProbeReadForId(ENCODER_CURRENT_ID, PROBE_TIMEOUT_MS) == 0U) {
#if UART_LOG_ENABLE
    printf("CURRENT ID not detected: 0x%02X\r\n", ENCODER_CURRENT_ID);
#endif
    return HAL_ERROR;
  }

  for (uint8_t attempt = 0U; attempt < COMMAND_RETRY_COUNT; attempt++) {
    /* Some units ACK with non-zero codes, so success is decided by probing the target ID afterward. */
    if (CAN_SendSetIdCommand(ENCODER_CURRENT_ID, ENCODER_TARGET_ID) != HAL_OK) {
      HAL_Delay(10);
      continue;
    }
    (void)CAN_WaitForAck(CMD_SET_ID, ACK_TIMEOUT_MS);
    HAL_Delay(50);
    if (CAN_ProbeReadForId(ENCODER_TARGET_ID, PROBE_TIMEOUT_MS) != 0U) {
      activeEncoderId = ENCODER_TARGET_ID;
      return HAL_OK;
    }
  }

  return HAL_ERROR;
}

static HAL_StatusTypeDef CAN_EnsureTargetBaud(void)
{
  if (ENCODER_CURRENT_BAUD_CODE == ENCODER_TARGET_BAUD_CODE) {
#if UART_LOG_ENABLE
    printf("BAUD change skipped\r\n");
#endif
    return HAL_OK;
  }

  for (uint8_t attempt = 0U; attempt < COMMAND_RETRY_COUNT; attempt++) {
    /* After changing baud, the host must reinitialize CAN before probing again. */
    if (CAN_SendSetBaudCommand(activeEncoderId, ENCODER_TARGET_BAUD_CODE) != HAL_OK) {
      HAL_Delay(10);
      continue;
    }
    (void)CAN_WaitForAck(CMD_SET_BAUD, ACK_TIMEOUT_MS);
    HAL_Delay(50);
    if (CAN_ReInitForBaudCode(ENCODER_TARGET_BAUD_CODE) != HAL_OK) {
      return HAL_ERROR;
    }
    if (CAN_ProbeReadForId(activeEncoderId, PROBE_TIMEOUT_MS) != 0U) {
      return HAL_OK;
    }
    if (CAN_ReInitForBaudCode(ENCODER_CURRENT_BAUD_CODE) != HAL_OK) {
      return HAL_ERROR;
    }
  }

  return HAL_ERROR;
}
