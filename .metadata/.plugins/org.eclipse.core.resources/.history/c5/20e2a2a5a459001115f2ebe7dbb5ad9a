/* ── ISR ──────────────────────────────────────────────────────────────────── */
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
    CAN_RxHeaderTypeDef hdr;
    uint8_t             d[8];

    if (hcan->Instance != CAN1) return;
    if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &hdr, d) != HAL_OK) return;

#if UART_LOG_ENABLE
    /* DEBUG: ирж буй бүх frame raw хэлбэрээр print — шалгаж дуусаад устга */
    printf("RX ide=%u std=0x%03X dlc=%u [%02X %02X %02X %02X %02X %02X %02X %02X]\r\n",
           (unsigned int)hdr.IDE,
           (unsigned int)hdr.StdId,
           (unsigned int)hdr.DLC,
           d[0],d[1],d[2],d[3],d[4],d[5],d[6],d[7]);
#endif

    /* EXT frame бол хаях (Briter STD frame ашигладаг) */
    if (hdr.IDE != CAN_ID_STD) return;

    /* SET_ID / SET_BAUD ACK: [0x04][newId/sameId][cmd][code] */
    if ((hdr.DLC >= 4U) &&
        (d[0] == 0x04U) &&
        ((d[2] == CMD_SET_ID) || (d[2] == CMD_SET_BAUD))) {
        s_cmdAckSeen = 1U;
        s_cmdAckType = d[2];
        s_cmdAckCode = d[3];
#if UART_LOG_ENABLE
        printf("RX ACK cmd=0x%02X code=%u id=0x%02X\r\n",
               (unsigned int)s_cmdAckType,
               (unsigned int)s_cmdAckCode,
               (unsigned int)hdr.StdId);
#endif
        return;
    }

    /* Echo шүүх: [0x04][id][0x01][0x00] DLC=4 */
    if ((hdr.DLC == 4U) &&
        (d[0] == 0x04U) && (d[2] == CMD_READ_VALUE) && (d[3] == 0x00U)) {
        return;
    }

    /* Read response: DLC=7, [0x07][id][0x01][D0..D3] */
    if ((hdr.StdId == (uint32_t)s_activeId) &&
        (hdr.DLC   == 7U)                   &&
        (d[0]      == 0x07U)                &&
        (d[1]      == s_activeId)           &&
        (d[2]      == CMD_READ_VALUE)) {
        s_readSeen = 1U;
    }
}

