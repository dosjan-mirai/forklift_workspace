static HAL_StatusTypeDef CAN_ReInitForBaudCode(uint8_t baudCode)
{
    /* Зогсоож, prescaler солиод, дахин init + filter/start хийнэ.
       WEncoder_CAN_FilterStart — zөвхөн filter+notify+start,
       baud-ийг дарж бичдэггүй тул config tool-д тохиромжтой. */
    (void)HAL_CAN_Stop(&hcan1);
    (void)HAL_CAN_DeInit(&hcan1);

    hcan1.Init.SyncJumpWidth = CAN_SJW_1TQ;
    hcan1.Init.TimeSeg1      = CAN_BS1_13TQ;
    hcan1.Init.TimeSeg2      = CAN_BS2_2TQ;

    switch (baudCode) {
        case WENC_BAUD_500K: hcan1.Init.Prescaler = 6;  break;  /* 48M/( 6*16)=500K */
        case WENC_BAUD_1M:   hcan1.Init.Prescaler = 3;  break;  /* 48M/( 3*16)=1M   */
        case WENC_BAUD_250K: hcan1.Init.Prescaler = 12; break;  /* 48M/(12*16)=250K */
        case WENC_BAUD_125K: hcan1.Init.Prescaler = 24; break;  /* 48M/(24*16)=125K */
        case WENC_BAUD_100K: hcan1.Init.Prescaler = 30; break;  /* 48M/(30*16)=100K */
        default: return HAL_ERROR;
    }

    if (HAL_CAN_Init(&hcan1) != HAL_OK) return HAL_ERROR;

    /* FilterStart: prescaler-ийг өөрчлөхгүй, зөвхөн filter+notify+start */
    g_wenc.hcan = &hcan1;
    return WEncoder_CAN_FilterStart();
}

static HAL_StatusTypeDef CAN_Send4(uint8_t stdId,
                                    uint8_t b0, uint8_t b1,
                                    uint8_t b2, uint8_t b3)
{
    CAN_TxHeaderTypeDef tx;
    uint8_t  data[8] = {b0, b1, b2, b3, 0, 0, 0, 0};
    uint32_t mailbox  = 0U;

    if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) == 0U) return HAL_BUSY;

    tx.StdId              = stdId;
    tx.IDE                = CAN_ID_STD;
    tx.RTR                = CAN_RTR_DATA;
    tx.DLC                = 4U;
    tx.TransmitGlobalTime = DISABLE;

    return HAL_CAN_AddTxMessage(&hcan1, &tx, data, &mailbox);
}

/* Encoder-ийг read request-ээр probe хийж, хариу ирвэл 1 буцаана */
static uint8_t CAN_ProbeId(uint8_t encoderId, uint32_t timeoutMs)
{
    uint32_t t0 = HAL_GetTick();
    s_activeId = encoderId;
    s_readSeen = 0U;

    while ((HAL_GetTick() - t0) < timeoutMs) {
        if ((HAL_GetTick() - s_reqSentAt) >= 20U) {
#if UART_LOG_ENABLE
            printf("TX READ id=0x%02X\r\n", encoderId);
#endif
            (void)CAN_Send4(encoderId, 0x04U, encoderId, CMD_READ_VALUE, 0x00U);
            s_reqSentAt = HAL_GetTick();
        }
        if (s_readSeen) {
#if UART_LOG_ENABLE
            printf("PROBE OK id=0x%02X\r\n", encoderId);
#endif
            return 1U;
        }
    }
    return 0U;
}

/* ACK ирэх хүртэл хүлээх */
static HAL_StatusTypeDef CAN_WaitAck(uint8_t expectedCmd, uint32_t timeoutMs)
{
    uint32_t t0 = HAL_GetTick();
    s_cmdAckSeen = 0U;
    s_cmdAckCode = 0xFFU;
    s_cmdAckType = 0x00U;

    while ((HAL_GetTick() - t0) < timeoutMs) {
        if (s_cmdAckSeen && (s_cmdAckType == expectedCmd)) return HAL_OK;
    }
    return HAL_TIMEOUT;
}

/* ── Config логик ─────────────────────────────────────────────────────────── */

static HAL_StatusTypeDef CAN_EnsureTargetId(void)
{
    if (ENCODER_CURRENT_ID == ENCODER_TARGET_ID) {
#if UART_LOG_ENABLE
        printf("ID change skipped (same)\r\n");
#endif
        s_activeId = ENCODER_TARGET_ID;
        return HAL_OK;
    }

    if (!CAN_ProbeId(ENCODER_CURRENT_ID, PROBE_TIMEOUT_MS)) {
#if UART_LOG_ENABLE
        printf("CURRENT ID 0x%02X not found\r\n", ENCODER_CURRENT_ID);
#endif
        return HAL_ERROR;
    }

    for (uint8_t i = 0U; i < COMMAND_RETRY_COUNT; i++) {
#if UART_LOG_ENABLE
        printf("TX SET_ID 0x%02X → 0x%02X\r\n",
               ENCODER_CURRENT_ID, ENCODER_TARGET_ID);
#endif
        if (CAN_Send4(ENCODER_CURRENT_ID,
                      0x04U, ENCODER_CURRENT_ID,
                      CMD_SET_ID, ENCODER_TARGET_ID) != HAL_OK) {
            HAL_Delay(10U);
            continue;
        }
        (void)CAN_WaitAck(CMD_SET_ID, ACK_TIMEOUT_MS);
        HAL_Delay(50U);

        if (CAN_ProbeId(ENCODER_TARGET_ID, PROBE_TIMEOUT_MS)) {
            s_activeId = ENCODER_TARGET_ID;
            return HAL_OK;
        }
    }
    return HAL_ERROR;
}

static HAL_StatusTypeDef CAN_EnsureTargetBaud(void)
{
    if (ENCODER_CURRENT_BAUD_CODE == ENCODER_TARGET_BAUD_CODE) {
#if UART_LOG_ENABLE
        printf("BAUD change skipped (same)\r\n");
#endif
        return HAL_OK;
    }

    for (uint8_t i = 0U; i < COMMAND_RETRY_COUNT; i++) {
#if UART_LOG_ENABLE
        printf("TX SET_BAUD → %u\r\n", (unsigned int)ENCODER_TARGET_BAUD_CODE);
#endif
        if (CAN_Send4(s_activeId,
                      0x04U, s_activeId,
                      CMD_SET_BAUD, ENCODER_TARGET_BAUD_CODE) != HAL_OK) {
            HAL_Delay(10U);
            continue;
        }
        (void)CAN_WaitAck(CMD_SET_BAUD, ACK_TIMEOUT_MS);
        HAL_Delay(50U);

        /* Host-ыг шинэ baud руу шилжүүлж probe хийх */
        if (CAN_ReInitForBaudCode(ENCODER_TARGET_BAUD_CODE) != HAL_OK) return HAL_ERROR;
        if (CAN_ProbeId(s_activeId, PROBE_TIMEOUT_MS)) return HAL_OK;

        /* Амжилтгүй — хуучин baud руу буцаж дараагийн оролдлого */
        if (CAN_ReInitForBaudCode(ENCODER_CURRENT_BAUD_CODE) != HAL_OK) return HAL_ERROR;
    }
    return HAL_ERROR;
}

