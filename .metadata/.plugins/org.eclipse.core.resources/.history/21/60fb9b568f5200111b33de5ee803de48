 void RobStride_HandleLiveCommand(void)
{
  if (g_live_apply == 0U)
  {
    return;
  }
  g_live_apply = 0U;

  if (g_live_cmd == LIVE_CMD_RUN_ALL_TESTS)
  {
    g_live_cmd = LIVE_CMD_NONE;
    RobStride_RunAllModeTests();
    return;
  }

  if (g_live_cmd == LIVE_CMD_MAX_TORQUE)
  {
    g_live_cmd = LIVE_CMD_NONE;
    RobStride_RunMaxTorque();
  }
}
