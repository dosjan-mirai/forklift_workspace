/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART3_UART_Init();
  MX_CAN1_Init();
  MX_SPI4_Init();
  /* USER CODE BEGIN 2 */
  UartLog("\r\n");
   UartLog("===== RS00 PP POSITION TEST =====\r\n");

   /* Read initial VBUS */
   if (RobStride_ReadParam(ROBSTRIDE_IDX_VBUS) != HAL_OK)
   {
       UartLog("[ERR] Read VBUS TX fail\r\n");
   }

   HAL_Delay(50);

   RobStride_ProcessRx();

   /* Enable periodic feedback */
   if (RobStride_EnableActiveReport(10U) != HAL_OK)
   {
       UartLog("[ERR] ActiveReport TX fail\r\n");
   }

   HAL_Delay(50);

   RobStride_ReadAllParams();

   HAL_Delay(50);

   RobStride_ProcessRx();

   /* CLEAR FAULT */
   RobStride_SendStop(
       ROBSTRIDE_CAN_HOST_ID,
       ROBSTRIDE_CAN_MOTOR_ID,
       1U);

   HAL_Delay(100);

   /* POSITION MODE */
   if (RobStride_WriteU8(
           ROBSTRIDE_IDX_RUN_MODE,
           ROBSTRIDE_MODE_PP_POS) != HAL_OK)
   {
       UartLog("[ERR] Set PP mode fail\r\n");
   }

   HAL_Delay(50);

   /* ENABLE MOTOR */
   if (RobStride_SendEnable(
           ROBSTRIDE_CAN_HOST_ID,
           ROBSTRIDE_CAN_MOTOR_ID) != HAL_OK)
   {
       UartLog("[ERR] Enable fail\r\n");
   }

   HAL_Delay(100);

   /* LIMITS */
   RobStride_WriteFloat(ROBSTRIDE_IDX_LIMIT_TRQ, 15.0f);
   HAL_Delay(20);

   RobStride_WriteFloat(ROBSTRIDE_IDX_VEL_MAX, 10.0f);
   HAL_Delay(20);

   RobStride_WriteFloat(ROBSTRIDE_IDX_ACC_SET, 3.0f);
   HAL_Delay(20);

   UartLog("[OK] PP mode configured\r\n");

   RobStride_LogCanDiag("POST_INIT");
   HAL_SPI_TransmitReceive_IT(
       &hspi4,
       (uint8_t*)&spi_tx,
       (uint8_t*)&spi_rx,
       sizeof(SpiPacket));
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
	  if(HAL_GPIO_ReadPin(SW2_GPIO_Port, SW2_Pin) == GPIO_PIN_SET)
	     {
		  RobStride_WriteFloat(
		 	                  ROBSTRIDE_IDX_LOC_REF,
		 					  0.4);
	     }
	     else
	     {
	    	 RobStride_WriteFloat(
	    	 	                  ROBSTRIDE_IDX_LOC_REF,
	    	 					 -0.5);
	     }


	          RobStride_ProcessRx();
	          RobStride_HandleLiveCommand();
	          HAL_Delay(1);

}
  /* USER CODE END 3 */
}

