/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration -------------------------------------------------------*/
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  MX_GPIO_Init();
  MX_USART3_UART_Init();
  MX_CAN1_Init();

  /* USER CODE BEGIN 2 */

  /* 1. Library init */
  WEncoder_CAN_Init(&hcan1);

  /* 2. Encoder(уудаа) бүртгэх — хэдэн ч болно */
  WEncoder_CAN_AddEncoder(ENCODER_ID, "Main",
                           TOTAL_COUNTS, RESOLUTION_MM, MAX_STEP_COUNTS);

  /* 3. CAN filter, baud тохируулж start хийх */
  if (WEncoder_CAN_StartStack() != HAL_OK) {
      Error_Handler();
  }

#if UART_LOG_ENABLE
  printf("\r\nBOOT OK | baud=1M encoder_id=0x%02X\r\n", ENCODER_ID);
#endif

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
      /* Poll: request илгээж, pending RX frame боловсруулна */
      WEncoder_CAN_Poll();

      /* Утга унших */
      WEnc_Reading_t r;
      if (WEncoder_CAN_GetByIndex(0U, &r) && r.valid)
      {
#if UART_LOG_ENABLE
          uint32_t now = HAL_GetTick();
          if ((now - lastPrintAt) >= PRINT_INTERVAL_MS) {
              printf("id=0x%02X | Raw: %6ld | Disp: %8.3f mm\r\n",
                     (unsigned int)r.can_id,
                     (long)r.raw,
                     (double)r.disp_mm);
              lastPrintAt = now;
          }
#endif
      }

      /* Timeout шалгах */
      if (WEncoder_CAN_IsTimeout(0U)) {
#if UART_LOG_ENABLE
          static uint32_t lastTimeoutAt = 0U;
          if ((HAL_GetTick() - lastTimeoutAt) >= 1000U) {
              printf("ENCODER TIMEOUT\r\n");
              lastTimeoutAt = HAL_GetTick();
          }
#endif
          HAL_GPIO_WritePin(LD3_GPIO_Port, LD3_Pin, GPIO_PIN_SET);   /* улаан LED */
      } else {
          HAL_GPIO_WritePin(LD1_GPIO_Port, LD1_Pin, GPIO_PIN_SET);   /* ногоон LED */
      }

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

