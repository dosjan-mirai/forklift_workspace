/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART3_UART_Init();
  MX_CAN1_Init();
  /* USER CODE BEGIN 2 */
  uint32_t prev = HAL_GetTick();
  if (CAN_PUSH_BAUD_TO_ENCODER_AT_BOOT != 0U) {
	  (void)CAN_SendSetBaudCommand(CAN_RUN_BAUD_CODE);
	  HAL_Delay(30);
  }
  if (CAN_RUN_BAUD_CODE != CAN_BOOT_BAUD_CODE) {
	  (void)CAN_ReInitForBaudCode(CAN_RUN_BAUD_CODE);
  }
  printf("\r\nFW_V3_PROD_READ | boot=%u run=%u profile=%lu\r\n",
		 (unsigned int)CAN_BOOT_BAUD_CODE,
		 (unsigned int)CAN_RUN_BAUD_CODE,
		 (unsigned long)CAN_TIMING_PROFILE);

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	if (canRxPending != 0U) {
		uint8_t rx[8];
		uint8_t dlc;
		uint16_t stdid;
		uint32_t raw;
		float disp;

		__disable_irq();
		dlc = canRxLen;
		stdid = canRxStdId;
		for (uint8_t i = 0U; i < 8U; i++) {
			rx[i] = canRxData[i];
		}
		canRxPending = 0U;
		__enable_irq();

		raw = (uint32_t)rx[3]
		    | ((uint32_t)rx[4] << 8)
		    | ((uint32_t)rx[5] << 16)
		    | ((uint32_t)rx[6] << 24);
		encoderValue = (int32_t)raw;

		if (!baselineSet) {
			baselineValue = encoderValue;
			baselineSet = true;
			printf("Auto baseline: %ld\r\n", (long)baselineValue);
		}

		disp = calcDisplacement(encoderValue, baselineValue);
		printf("RX id=0x%03X dlc=%u | Raw: %6ld | Disp: %8.3f mm\r\n",
		       (unsigned int)stdid, (unsigned int)dlc, (long)encoderValue, (double)disp);
	}

	if ((HAL_GetTick() - prev) >= REQUEST_INTERVAL_MS) {
		if (requestPending == 0U) {
			reqEncoderValue();
		} else if ((HAL_GetTick() - requestSentAt) > RESPONSE_TIMEOUT_MS) {
			(void)HAL_CAN_AbortTxRequest(&hcan1, CAN_TX_MAILBOX0 | CAN_TX_MAILBOX1 | CAN_TX_MAILBOX2);
			requestPending = 0U;
		}
		prev = HAL_GetTick();
	}
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

