#define ENCODER_ID           0x01U
#define RESOLUTION_MM        0.0244f
#define CMD_READ_VALUE       0x01U
#define CMD_SET_BAUD         0x03U

#define TOTAL_COUNTS         98300
#define REQUEST_INTERVAL_MS  20
#define RESPONSE_TIMEOUT_MS  200U
#define CAN_TIMING_PROFILE    3U  /* 1:A(default), 2:B, 3:C */
#define CAN_DISCOVERY_MODE    0U  /* 1:scan IDs 1..32, 0:fixed ENCODER_ID */

#define CAN_BAUD_500K        0x00U
#define CAN_BAUD_1M          0x01U
#define CAN_BAUD_250K        0x02U
#define CAN_BAUD_125K        0x03U
#define CAN_BAUD_100K        0x04U

/* Production flags */
#define CAN_BOOT_BAUD_CODE                CAN_BAUD_500K
#define CAN_RUN_BAUD_CODE                 CAN_BAUD_500K
#define CAN_PUSH_BAUD_TO_ENCODER_AT_BOOT  0U

static volatile uint8_t requestPending = 0U;
static uint32_t requestSentAt = 0U;
static uint32_t lastCanLogAt = 0U;

int __io_putchar(int ch)
{
  uint8_t c = (uint8_t)ch;
  (void)HAL_UART_Transmit(&huart3, &c, 1U, 100U);
  return ch;
}

float calcDisplacement(int32_t raw, int32_t baseline) {
  int32_t delta = raw - baseline;

  // Wrap-around засвар
  if (delta > TOTAL_COUNTS / 2) {
    delta -= TOTAL_COUNTS;   // Жишээ: 98300 → 98300-98303 = -3
  } else if (delta < -(TOTAL_COUNTS / 2)) {
    delta += TOTAL_COUNTS;
  }

  return (float)delta * RESOLUTION_MM;
}

void reqEncoderValue(void){
	CAN_TxHeaderTypeDef tx_header;
	uint8_t data[8];
	uint32_t pTxMailbox;
	uint32_t now = HAL_GetTick();
	uint16_t targetId = ENCODER_ID;
#if CAN_DISCOVERY_MODE
	static uint16_t g_scanId = 2U;
	targetId = g_scanId;
#endif
	tx_header.StdId=targetId;
	tx_header.IDE=CAN_ID_STD;
	tx_header.RTR=CAN_RTR_DATA;
	tx_header.DLC=4;
	tx_header.TransmitGlobalTime = DISABLE;
	
	data[0]=0x04;
	data[1]=(uint8_t)targetId;
	data[2]=CMD_READ_VALUE;
	data[3]=0x00;
	data[4]=0x00;
	data[5]=0x00;
	data[6]=0x00;
	data[7]=0x00;

	if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) == 0U) {
		return;
	}

	if (HAL_CAN_AddTxMessage(&hcan1, &tx_header, data, &pTxMailbox) != HAL_OK) {
		return;
	}
	requestPending = 1U;
	requestSentAt = now;
#if CAN_DISCOVERY_MODE
	g_scanId++;
	if (g_scanId > 32U) g_scanId = 1U;
#endif
}

void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
	CAN_RxHeaderTypeDef rx_header;
	uint8_t rx_data[8];

	if (hcan->Instance != CAN1) {
		return;
	}

	if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rx_header, rx_data) != HAL_OK) {
		return;
	}

	/* Drop our own polling request echo: [04][id][01][00], DLC=4 */
	if ((rx_header.IDE == CAN_ID_STD) &&
	    (rx_header.DLC == 4U) &&
	    (rx_data[0] == 0x04U) &&
	    (rx_data[2] == CMD_READ_VALUE) &&
	    (rx_data[3] == 0x00U)) {
		return;
	}

	if ((rx_header.IDE != CAN_ID_STD) || (rx_header.DLC < 7U)) {
		return;
	}
	if (rx_data[0] != 0x07U) {
		return;
	}
	if (rx_data[2] != CMD_READ_VALUE) {
		return;
	}

	canRxStdId = rx_header.StdId;
	canRxLen = rx_header.DLC;
	for (uint8_t i = 0U; i < 8U; i++) {
		canRxData[i] = rx_data[i];
	}
	canRxPending = 1U;
	requestPending = 0U;
}

void HAL_CAN_ErrorCallback(CAN_HandleTypeDef *hcan)
{
	uint32_t now;
	uint32_t err;
	uint32_t esr;

	if (hcan->Instance != CAN1) {
		return;
	}

	now = HAL_GetTick();
	err = HAL_CAN_GetError(hcan);
	esr = CAN1->ESR;

	if ((now - lastCanLogAt) >= 1000U) {
		printf("CAN err=0x%08lX LEC=%lu TEC=%lu REC=%lu\r\n",
		       (unsigned long)err,
		       (unsigned long)((esr & CAN_ESR_LEC_Msk) >> CAN_ESR_LEC_Pos),
		       (unsigned long)((esr & CAN_ESR_TEC_Msk) >> CAN_ESR_TEC_Pos),
		       (unsigned long)((esr & CAN_ESR_REC_Msk) >> CAN_ESR_REC_Pos));
		lastCanLogAt = now;
	}

	if (((esr & CAN_ESR_BOFF) != 0U) || ((err & HAL_CAN_ERROR_BOF) != 0U)) {
		(void)HAL_CAN_Stop(hcan);
		(void)HAL_CAN_Start(hcan);
		requestPending = 0U;
	}
}

static HAL_StatusTypeDef CAN_StartStack(void)
{
	sFilterConfig.FilterBank = 0;
	sFilterConfig.FilterMode = CAN_FILTERMODE_IDMASK;
	sFilterConfig.FilterScale = CAN_FILTERSCALE_32BIT;
	sFilterConfig.FilterIdHigh = 0x0000;
	sFilterConfig.FilterIdLow = 0x0000;
	sFilterConfig.FilterMaskIdHigh = 0x0000;
	sFilterConfig.FilterMaskIdLow = 0x0000;
	sFilterConfig.FilterFIFOAssignment = CAN_RX_FIFO0;
	sFilterConfig.FilterActivation = ENABLE;
	sFilterConfig.SlaveStartFilterBank = 14;

	if (HAL_CAN_ConfigFilter(&hcan1, &sFilterConfig) != HAL_OK) {
		return HAL_ERROR;
	}
	if (HAL_CAN_ActivateNotification(&hcan1,
			CAN_IT_RX_FIFO0_MSG_PENDING |
			CAN_IT_TX_MAILBOX_EMPTY |
			CAN_IT_BUSOFF |
			CAN_IT_ERROR |
			CAN_IT_LAST_ERROR_CODE) != HAL_OK) {
		return HAL_ERROR;
	}
	if (HAL_CAN_Start(&hcan1) != HAL_OK) {
		return HAL_ERROR;
	}
	return HAL_OK;
}

static HAL_StatusTypeDef CAN_ApplyBitTimingFromBaudCode(uint8_t baudCode)
{
	/* APB1 = 48MHz (from current clock tree: SYSCLK 192MHz, APB1 div4). */
	hcan1.Init.SyncJumpWidth = CAN_SJW_1TQ;
	hcan1.Init.TimeSeg1 = CAN_BS1_13TQ;
	hcan1.Init.TimeSeg2 = CAN_BS2_2TQ;

	switch (baudCode) {
	case CAN_BAUD_500K: hcan1.Init.Prescaler = 6;  break;  /* 48M/(6*16)=500k */
	case CAN_BAUD_1M:   hcan1.Init.Prescaler = 3;  break;  /* 48M/(3*16)=1M   */
	case CAN_BAUD_250K: hcan1.Init.Prescaler = 12; break;  /* 48M/(12*16)=250k */
	case CAN_BAUD_125K: hcan1.Init.Prescaler = 24; break;  /* 48M/(24*16)=125k */
	case CAN_BAUD_100K: hcan1.Init.Prescaler = 30; break;  /* 48M/(30*16)=100k */
	default:
		return HAL_ERROR;
	}
	return HAL_OK;
}

static HAL_StatusTypeDef CAN_ReInitForBaudCode(uint8_t baudCode)
{
	(void)HAL_CAN_Stop(&hcan1);
	(void)HAL_CAN_DeInit(&hcan1);
	if (CAN_ApplyBitTimingFromBaudCode(baudCode) != HAL_OK) {
		return HAL_ERROR;
	}
	if (HAL_CAN_Init(&hcan1) != HAL_OK) {
		return HAL_ERROR;
	}
	return CAN_StartStack();
}

static HAL_StatusTypeDef CAN_SendSetBaudCommand(uint8_t baudCode)
{
	CAN_TxHeaderTypeDef tx_header;
	uint8_t data[8] = {0U};
	uint32_t mailbox = 0U;

	if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) == 0U) {
		return HAL_BUSY;
	}

	tx_header.StdId = ENCODER_ID;
	tx_header.IDE = CAN_ID_STD;
	tx_header.RTR = CAN_RTR_DATA;
	tx_header.DLC = 4U;
	tx_header.TransmitGlobalTime = DISABLE;

	data[0] = 0x04U;
	data[1] = ENCODER_ID;
	data[2] = CMD_SET_BAUD;
	data[3] = baudCode;

	return HAL_CAN_AddTxMessage(&hcan1, &tx_header, data, &mailbox);
}

